# e-depot API — variables d'environnement
# PostgreSQL (obligatoire). En prod, Render injecte DATABASE_URL depuis la base managée.
DATABASE_URL="postgresql://user:password@host:5432/edepot?schema=public"

# Secret de signature JWT — LONG et aléatoire en prod (Render peut le générer).
JWT_SECRET="change-me-with-a-long-random-secret"
JWT_EXPIRES_IN="12h"

# Port d'écoute (Render fournit PORT automatiquement).
PORT=3001

# Origine(s) autorisée(s) pour le CORS, séparées par des virgules.
# En prod : l'URL du site Netlify, ex. https://e-depot-ci.netlify.app
CORS_ORIGIN="http://localhost:5173"
