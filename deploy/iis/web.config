<?xml version="1.0" encoding="UTF-8"?>
<!--
  Reverse proxy IIS pour exposer e-depot sous  http://ci-apps.medlog.com/e-depot
  vers le site Netlify (front) — l'API reste appelée directement sur Render.

  PRÉREQUIS sur le serveur IIS (une fois) :
    1. Installer "URL Rewrite" et "Application Request Routing (ARR)"
       (Web Platform Installer, ou téléchargements Microsoft).
    2. IIS Manager → noeud du serveur → "Application Request Routing Cache"
       → "Server Proxy Settings…" → cocher "Enable proxy" → Apply.

  Déposer ce web.config à la RACINE du site qui répond sur ci-apps.medlog.com
  (ou dans une application IIS). Le préfixe /e-depot est conservé et transmis à
  Netlify, qui sert l'app sous ce même sous-chemin (base Vite = /e-depot/).
-->
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <rule name="Proxy e-depot -> Netlify" stopProcessing="true">
          <match url="^e-depot(/.*)?$" />
          <action type="Rewrite" url="https://e-depot.netlify.app/e-depot{R:1}" />
        </rule>
      </rules>
    </rewrite>
    <!-- ARR envoie l'en-tête Host du backend (e-depot.netlify.app), requis par Netlify. -->
    <proxy xmlns="urn:ARRConfig" preserveHostHeader="false" />
  </system.webServer>
</configuration>
